          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\r\n  COALESCE(\r\n    SUM(\r\n      p.precio * GREATEST(COALESCE(p.stock_actual, p.cantidad, 0), 0)\r\n    ),\r\n    0\r\n  ) AS perdida_potencial\r\nFROM productos p\r\nWHERE p.eliminado IS NULL\r\n  AND p.precio > 0\r\n  AND COALESCE(p.stock_actual, p.cantidad, 0) > 0\r\n  AND p.caducidad BETWEEN CURDATE() AND DATE_ADD(CURDATE(), INTERVAL 7 DAY);",
          "refId": "A",
